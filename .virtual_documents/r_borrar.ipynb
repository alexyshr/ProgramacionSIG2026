cat("\n=== METADATOS ===\n")
print(st_get_dimension_values(st_col5d, names(st_dimensions(st_col5d))[1]))

# (Nota: stars no expone attrs globales tan directo como xarray/Julia)

# -------------------------------------------------------------------------
# Forma
# -------------------------------------------------------------------------

cat("\n=== SHAPE ===\n")
